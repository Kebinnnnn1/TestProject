{
  "expo": {
    "name": "CUlink",
    "slug": "culink-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1117"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.culink.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1117"
      },
      "package": "com.culink.mobile",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "CUlink needs access to your photos to upload images.",
          "cameraPermission": "CUlink needs access to your camera."
        }
      ]
    ],
    "scheme": "culink",
    "extra": {
      "eas": {
        "projectId": "3a7795bf-5736-45a7-b78d-58d3e50fb18e"
      }
    },
    "owner": "kebintong"
  }
}
